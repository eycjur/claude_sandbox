FROM docker/sandbox-templates:shell

ARG YAZI_VERSION=v26.5.6

ENV DEBIAN_FRONTEND=noninteractive
ENV IS_SANDBOX=1

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl git jq less make sudo \
      python-is-python3 python3 ripgrep zsh && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g @anthropic-ai/claude-code @openai/codex hunkdiff && \
    chsh -s /bin/zsh agent && \
    rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.11.25 /uv /uvx /bin/

# yazi はターミナルファイラー。プレビュー機能（画像/動画/PDF）用の
# 依存パッケージも含める。リリースの glibc 向け .deb は aarch64 / x86_64 の
# 2 種類のため、ビルド時のアーキテクチャで出し分ける。
RUN case "$(uname -m)" in \
      aarch64) yazi_arch=aarch64 ;; \
      x86_64)  yazi_arch=x86_64 ;; \
      *) echo "unsupported architecture for yazi: $(uname -m)" >&2; exit 1 ;; \
    esac && \
    apt-get update && \
    curl -fsSL -o /tmp/yazi.deb \
      https://github.com/sxyazi/yazi/releases/download/${YAZI_VERSION}/yazi-${yazi_arch}-unknown-linux-gnu.deb && \
    apt-get install -y /tmp/yazi.deb && \
    rm /tmp/yazi.deb && \
    rm -rf /var/lib/apt/lists/*

# 認証情報ファイルは `sbx cp` でサンドボックス作成後にコピーする
# （internal/home 参照）。コピー先の親ディレクトリだけ先に用意しておく。
RUN mkdir -p /home/agent/.claude /home/agent/.codex && \
    chown -R agent:agent /home/agent/.claude /home/agent/.codex

USER agent

# git.yazi プラグイン本体のみ取得する。init.lua / yazi.toml 側の有効化設定は
# 各自の dotfiles で管理する想定。
RUN ya pkg add yazi-rs/plugins:git
